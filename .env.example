# Published Google Sheets CSV URL for the Events calendar.
# File → Share → Publish to web → CSV
NEXT_PUBLIC_EVENTS_SHEET_URL=

# Anthropic API key — used server-side only for intake form AI generation.
# Get yours at: https://console.anthropic.com → API Keys
# Add this to Vercel: Project Settings → Environment Variables
ANTHROPIC_API_KEY=

# Resend — email sending (clinic notifications + intake results emails to parents).
# API key from resend.com → API Keys
RESEND_API_KEY=
# Audience ID from resend.com → Audiences → (your audience) → ID
RESEND_AUDIENCE_ID=

# Klaviyo — subscriber list management, welcome flow, and event tracking.
# Private API key from klaviyo.com → Account → Settings → API Keys (never expose to browser)
KLAVIYO_PRIVATE_API_KEY=
# Public site ID from klaviyo.com → Account → Settings → API Keys (safe to expose)
NEXT_PUBLIC_KLAVIYO_SITE_ID=
# List ID for the newsletter subscriber list from klaviyo.com → Lists & Segments
KLAVIYO_LIST_ID=
# List ID for the Contact Form Leads list from klaviyo.com → Lists & Segments
KLAVIYO_CONTACT_LIST_ID=
# Intake Form Leads list ID
KLAVIYO_INTAKE_LIST_ID=
