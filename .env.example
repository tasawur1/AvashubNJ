# Published Google Sheets CSV URL for the Events calendar.
# File → Share → Publish to web → CSV
NEXT_PUBLIC_EVENTS_SHEET_URL=

# Anthropic API key — used server-side only for intake form AI generation.
# Get yours at: https://console.anthropic.com → API Keys
# Add this to Vercel: Project Settings → Environment Variables
ANTHROPIC_API_KEY=

# Resend — email sending + audience/contact sync.
# API key from resend.com → API Keys
RESEND_API_KEY=
# Audience ID from resend.com → Audiences → (your audience) → ID
# Required for newsletter, contact form, and intake form submissions to sync contacts.
# Temporary until Klaviyo migration.
RESEND_AUDIENCE_ID=
